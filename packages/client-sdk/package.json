{
  "name": "@hello-devin/client-sdk",
  "version": "0.0.1",
  "description": "OpenAPI-generated TypeScript client SDK for Hello Devin backend services",
  "private": true,
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-typescript-codegen --input http://localhost:3000/api/docs-json --output src/generated --client axios",
    "generate:file": "openapi-typescript-codegen --input openapi.json --output src/generated --client axios",
    "build": "tsc",
    "clean": "rm -rf dist src/generated",
    "lint": "eslint \"{src}/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "openapi-typescript-codegen": "^0.29.0",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.7"
  }
}
